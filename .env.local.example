# ─── Supabase (self-hosted via EasyPanel) ────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=http://seu-supabase.dominio.com
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key

# ─── App ─────────────────────────────────────────────────────────────────────
# Domínio base sem protocolo (ex: clinicaos.com.br)
NEXT_PUBLIC_APP_DOMAIN=clinicaos.com.br

# ─── Opcional: SMTP para notificações ────────────────────────────────────────
# SMTP_HOST=smtp.seu-servidor.com
# SMTP_PORT=587
# SMTP_USER=no-reply@clinicaos.com.br
# SMTP_PASS=sua-senha-smtp
